<Window x:Class="CyberChatBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberChatBot"
        mc:Ignorable="d"
        Title="CyberChatBot - Cybersecurity Awareness Chat" Height="700" Width="1383"
        Background="#0d1117" Foreground="#e6edf3"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="0,0,0,-44">
        <Grid.RowDefinitions>
            <!-- Main content area — fills all available space -->
            <RowDefinition/>
            <!-- Status bar — fixed height at the bottom -->
            <RowDefinition Height="Auto" MinHeight="65.04"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════
             NAME ENTRY PANEL
             Shown on startup, hidden after name entered
        ══════════════════════════════════════════ -->
        <StackPanel x:Name="NamePanel"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="600" Height="364">

            <Border Background="#161b22" CornerRadius="12" Padding="36">
                <StackPanel>
                    <!-- Bot logo text -->
                    <TextBlock
                               FontSize="30" FontWeight="Bold"
                               Foreground="#58a6ff"
                               TextAlignment="Center"
                               Margin="0,0,0,6">
                        
                    <Run Text="Cyber"/>
                        <Run Language="en-za" Text="Chat"/>
                        <Run Text="Bot"/>
                    </TextBlock>

                    <TextBlock Text="Cybersecurity Awareness Bot"
                               FontSize="20"
                               Foreground="#58a6ff"
                               TextAlignment="Center"
                               Margin="0,0,0,4" Height="28"/>

                    <TextBlock Text="Your personal guide to staying safe online"
                               FontSize="15"
                               Foreground="White"
                               TextAlignment="Center"
                               Margin="0,0,0,28"/>

                    <!-- Divider -->
                    <Border BorderBrush="#30363d" BorderThickness="0,1,0,0" Margin="0,0,0,24"/>

                    <TextBlock Text="What's your name?"
                               FontSize="20"
                               Foreground="#c9d1d9"
                               Margin="0,0,0,8"/>

                    <!-- Name text box -->
                    <TextBox x:Name="NameInput"
                             Height="48"
                             Padding="12,10"
                             FontSize="15"
                             Background="#0d1117"
                             Foreground="#e6edf3"
                             CaretBrush="White"
                             BorderBrush="#30363d"
                             BorderThickness="1"
                             KeyDown="NameInput_KeyDown"
                             Margin="0,0,0,8"/>

                    <!-- Validation error message -->
                    <TextBlock x:Name="NameError"
                               Text="Please enter your name to continue."
                               Foreground="#f85149"
                               FontSize="12"
                               Visibility="Collapsed"
                               Margin="0,0,0,10"/>

                    <!-- Start Chat button -->
                    <Button x:Name="StartChatBtn"
                            Content="Start Chat"
                            Click="StartChat_Click"
                            Height="50"
                            Background="#238636"
                            Foreground="White"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            BorderThickness="0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ══════════════════════════════════════════
             CHAT PANEL
             Hidden until name is entered
        ══════════════════════════════════════════ -->
        <Grid x:Name="ChatContainer"
              Grid.Row="0"
              Visibility="Collapsed">

            <Grid.RowDefinitions>
                <!-- Header bar -->
                <RowDefinition Height="Auto"/>
                <!-- Scrollable chat messages -->
                <RowDefinition Height="*"/>
                <!-- Message input area -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header Bar -->
            <Border Grid.Row="0"
                    Background="#161b22"
                    Padding="16,12"
                    BorderBrush="#30363d"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Bot title and subtitle -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="🛡"
                                   FontSize="40"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CYBERSECURITY AWARENESS BOT"
                                       Foreground="#58a6ff"
                                       FontSize="40"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Your guide to staying safe online"
                                       Foreground="#8b949e"
                                       FontSize="15"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Secure session indicator -->
                    <TextBlock Grid.Column="1"
                               Text="Secure Session"
                               Foreground="#3fb950"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Chat Messages ScrollViewer -->
            <ScrollViewer x:Name="ChatScrollViewer"
                          Grid.Row="1"
                          Background="#0d1117"
                          VerticalScrollBarVisibility="Auto"
                          Padding="15,10">
                <StackPanel x:Name="ChatPanel" Orientation="Vertical"/>
            </ScrollViewer>

            <!-- Message Input Area -->
            <Border x:Name="InputArea"
                    Grid.Row="2"
                    Background="#161b22"
                    BorderBrush="#30363d"
                    BorderThickness="0,1,0,0"
                    Padding="15,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- Message text box -->
                        <ColumnDefinition Width="*"/>
                        <!-- Send button -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Clear button -->
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="UserInput"
                             Grid.Column="0"
                             Height="45"
                             Padding="12,10"
                             FontSize="13"
                             Background="#0d1117"
                             Foreground="#e6edf3"
                             CaretBrush="White"
                             BorderBrush="#30363d"
                             BorderThickness="1"
                             KeyDown="UserInput_KeyDown"
                             Margin="0,0,10,0"/>

                    <Button x:Name="SendButton"
                            Grid.Column="1"
                            Content="Send ➤"
                            Click="SendButton_Click"
                            Width="85" Height="45"
                            Background="#238636"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            BorderThickness="0"
                            Margin="0,0,8,0"/>

                    <Button x:Name="ClearButton"
                            Grid.Column="2"
                            Content="Clear Chat"
                            Click="ClearChat_Click"
                            Width="100" Height="45"
                            Background="#21262d"
                            Foreground="#8b949e"
                            BorderBrush="#30363d"
                            BorderThickness="1"
                            Cursor="Hand"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════
             STATUS BAR
             Always visible at the bottom of the window
        ══════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="#161b22"
                BorderBrush="#30363d"
                BorderThickness="0,1,0,0"
                Padding="15,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Dynamic status message -->
                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           Text="Enter your name to begin"
                           Foreground="#8b949e"
                           FontSize="11"/>

                <!-- Memory indicator -->
                <TextBlock Grid.Column="1"
                           Text="Memory: Active"
                           Foreground="#3fb950"
                           FontSize="11"/>
            </Grid>
        </Border>
    </Grid>
</Window>